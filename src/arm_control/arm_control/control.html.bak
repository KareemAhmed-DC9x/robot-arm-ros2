<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ARM CONTROL</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.5/socket.io.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Orbitron:wght@400;700;900&display=swap');

  :root {
    --bg:       #0a0c10;
    --panel:    #0f1318;
    --border:   #1e2530;
    --accent:   #00e5ff;
    --accent2:  #ff6b35;
    --green:    #00ff87;
    --red:      #ff3366;
    --text:     #c8d6e5;
    --dim:      #4a5568;
    --glow:     0 0 20px rgba(0,229,255,0.3);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Space Mono', monospace;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ---- HEADER ---- */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(90deg, #0a0c10 0%, #0d1420 100%);
  }

  .logo {
    font-family: 'Orbitron', monospace;
    font-size: 1.3rem;
    font-weight: 900;
    letter-spacing: .12em;
    color: var(--accent);
    text-shadow: var(--glow);
  }

  .logo span { color: var(--accent2); }

  #conn-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: .75rem;
    letter-spacing: .08em;
    color: var(--dim);
  }

  #conn-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--dim);
    transition: background .3s, box-shadow .3s;
  }

  #conn-dot.ok  { background: var(--green); box-shadow: 0 0 8px var(--green); }
  #conn-dot.err { background: var(--red);   box-shadow: 0 0 8px var(--red);   }

  /* ---- LAYOUT ---- */
  main {
    flex: 1;
    display: grid;
    grid-template-columns: 280px 1fr 280px;
    grid-template-rows: auto 1fr;
    gap: 1px;
    background: var(--border);
    overflow: hidden;
  }

  section {
    background: var(--panel);
    padding: 24px;
  }

  .sec-title {
    font-family: 'Orbitron', monospace;
    font-size: .65rem;
    letter-spacing: .15em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  /* ---- QUICK CONTROLS ---- */
  #sec-quick {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .btn {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    font-family: 'Space Mono', monospace;
    font-size: .78rem;
    letter-spacing: .06em;
    cursor: pointer;
    transition: all .15s;
    text-align: left;
  }

  .btn:hover         { border-color: var(--accent); color: var(--accent); background: rgba(0,229,255,.05); }
  .btn.danger        { border-color: #2a1420; }
  .btn.danger:hover  { border-color: var(--red); color: var(--red); background: rgba(255,51,102,.05); }
  .btn.success       { border-color: #0a2a1a; }
  .btn.success:hover { border-color: var(--green); color: var(--green); background: rgba(0,255,135,.05); }

  /* ---- MOTOR GRID ---- */
  #sec-motors {
    grid-column: 2;
    overflow-y: auto;
  }

  .motors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .motor-card {
    border: 1px solid var(--border);
    padding: 16px;
    transition: border-color .2s;
    position: relative;
    overflow: hidden;
  }

  .motor-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .3s;
  }

  .motor-card.active::before { transform: scaleX(1); }
  .motor-card.active { border-color: rgba(0,229,255,.3); }

  .motor-id {
    font-family: 'Orbitron', monospace;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .motor-pos {
    font-size: .7rem;
    color: var(--dim);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .motor-pos .val {
    font-size: .9rem;
    color: var(--text);
    font-weight: 700;
  }

  .moving-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--dim);
    transition: background .2s;
  }

  .moving-dot.on { background: var(--green); box-shadow: 0 0 6px var(--green); animation: pulse 1s infinite; }

  @keyframes pulse {
    0%,100% { opacity:1; }
    50%      { opacity:.3; }
  }

  label { display: block; font-size: .65rem; color: var(--dim); margin-bottom: 4px; letter-spacing: .06em; }

  input[type=number], input[type=range] {
    width: 100%;
    background: #070a0e;
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'Space Mono', monospace;
    font-size: .78rem;
    padding: 7px 10px;
    outline: none;
    transition: border-color .15s;
    margin-bottom: 10px;
  }

  input[type=number]:focus { border-color: var(--accent); }

  input[type=range] {
    padding: 4px 0;
    accent-color: var(--accent);
    cursor: pointer;
  }

  .range-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .range-row input[type=range] { margin-bottom: 0; flex: 1; }
  .range-val { font-size: .7rem; min-width: 48px; text-align: right; }

  .card-btns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }

  .card-btn {
    padding: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--dim);
    font-family: 'Space Mono', monospace;
    font-size: .65rem;
    cursor: pointer;
    transition: all .15s;
    letter-spacing: .04em;
  }

  .card-btn.move  { grid-column: 1 / -1; color: var(--accent); border-color: rgba(0,229,255,.3); }
  .card-btn.move:hover  { background: rgba(0,229,255,.1); border-color: var(--accent); }
  .card-btn.zero:hover  { color: var(--accent2); border-color: var(--accent2); }
  .card-btn.wait:hover  { color: var(--green); border-color: var(--green); }

  /* ---- LOG PANEL ---- */
  #sec-log {
    display: flex;
    flex-direction: column;
  }

  #log-box {
    flex: 1;
    overflow-y: auto;
    font-size: .68rem;
    line-height: 1.7;
    color: var(--dim);
    max-height: 600px;
  }

  #log-box .entry       { padding: 2px 0; border-bottom: 1px solid #0d1015; }
  #log-box .entry.tx    { color: var(--accent); }
  #log-box .entry.rx    { color: var(--green); }
  #log-box .entry.err   { color: var(--red); }
  #log-box .entry.info  { color: var(--dim); }

  .ts { color: #2a3545; margin-right: 6px; }

  /* ---- GLOBAL PARAMS ---- */
  #sec-params { grid-column: 1 / -1; border-top: 1px solid var(--border); }

  .params-row {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    align-items: flex-end;
  }

  .param-group { display: flex; flex-direction: column; gap: 4px; }
  .param-group label { font-size: .65rem; color: var(--dim); letter-spacing: .06em; }
  .param-group input { width: 120px; }

  /* ---- SCROLLBAR ---- */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); }
  ::-webkit-scrollbar-thumb:hover { background: var(--dim); }
</style>
</head>

<body>

<!-- HEADER -->
<header>
  <div class="logo">ARM<span>.</span>CONTROL</div>
  <div id="conn-badge">
    <div id="conn-dot"></div>
    <span id="conn-label">CONNECTING…</span>
  </div>
</header>

<!-- MAIN GRID -->
<main>

  <!-- LEFT: QUICK CONTROLS -->
  <section id="sec-quick">
    <div class="sec-title">⚡ QUICK</div>
    <button class="btn success" onclick="sendCmd('ENABLE')">▶  ENABLE DRIVERS</button>
    <button class="btn danger"  onclick="sendCmd('DISABLE')">■  DISABLE DRIVERS</button>
    <button class="btn danger"  onclick="sendCmd('STOP')">✕  STOP ALL</button>
    <button class="btn"         onclick="sendCmd('STATUS')">◎  REQUEST STATUS</button>
    <div style="margin-top:auto;padding-top:20px;font-size:.65rem;color:var(--dim);">
      <div>ROS2 Topic:</div>
      <div style="color:var(--accent);margin-top:4px;">/arm/cmd</div>
      <div style="margin-top:12px;">Status Topic:</div>
      <div style="color:var(--green);margin-top:4px;">/arm/status</div>
    </div>
  </section>

  <!-- CENTER: MOTOR CARDS -->
  <section id="sec-motors">
    <div class="sec-title">🦾 MOTORS  (1 – 6)</div>
    <div class="motors-grid" id="motors-grid"></div>
  </section>

  <!-- RIGHT: LOG -->
  <section id="sec-log">
    <div class="sec-title">📡 LOG</div>
    <div id="log-box"></div>
    <button class="btn" style="margin-top:10px;font-size:.65rem;"
            onclick="document.getElementById('log-box').innerHTML=''">CLEAR</button>
  </section>

</main>

<script>
// ============================================================
//  SOCKET.IO CONNECTION
// ============================================================
const socket = io({ transports: ['websocket'] });

const dot   = document.getElementById('conn-dot');
const label = document.getElementById('conn-label');

socket.on('connect',    () => { dot.className='ok';  label.textContent='CONNECTED'; log('Connected ✔','info'); });
socket.on('disconnect', () => { dot.className='err'; label.textContent='DISCONNECTED'; });
socket.on('status',     onStatus);

// ============================================================
//  MOTORS STATE
// ============================================================
const NUM = 6;
const state = {
  positions: Array(NUM).fill(0),
  moving:    Array(NUM).fill(false),
};

// Global defaults (editable via params section)
let gSpeed = 600;
let gAccel = 2000;

// ============================================================
//  BUILD MOTOR CARDS
// ============================================================
const grid = document.getElementById('motors-grid');

for (let i = 1; i <= NUM; i++) {
  const card = document.createElement('div');
  card.className = 'motor-card';
  card.id = `card-${i}`;
  card.innerHTML = `
    <div class="motor-id">M${i}</div>
    <div class="motor-pos">
      <div class="moving-dot" id="dot-${i}"></div>
      <span>POS</span>
      <span class="val" id="pos-${i}">0.00°</span>
    </div>

    <label>ANGLE (deg)</label>
    <div class="range-row">
      <input type="range" id="range-${i}" min="-180" max="180" value="0"
             oninput="document.getElementById('anginp-${i}').value=this.value">
      <span class="range-val" id="rangeval-${i}">0°</span>
    </div>
    <input type="number" id="anginp-${i}" value="0" step="1"
           placeholder="Angle °"
           oninput="syncRange(${i},this.value)">

    <label>SPEED (steps/s)</label>
    <input type="number" id="spdinp-${i}" value="600" step="50" placeholder="600">

    <label>ACCEL (steps/s²)</label>
    <input type="number" id="accinp-${i}" value="2000" step="100" placeholder="2000">

    <div class="card-btns">
      <button class="card-btn move" onclick="moveMotor(${i})">▶ MOVE</button>
      <button class="card-btn zero" onclick="zeroMotor(${i})">◎ ZERO</button>
      <button class="card-btn wait" onclick="moveWait(${i})">⏳ MOVE+WAIT</button>
    </div>
  `;
  grid.appendChild(card);

  // sync range ↔ number
  document.getElementById(`range-${i}`).addEventListener('input', function() {
    document.getElementById(`rangeval-${i}`).textContent = this.value + '°';
    document.getElementById(`anginp-${i}`).value = this.value;
  });
}

function syncRange(i, val) {
  const v = parseFloat(val) || 0;
  const r = document.getElementById(`range-${i}`);
  r.value = Math.min(180, Math.max(-180, v));
  document.getElementById(`rangeval-${i}`).textContent = r.value + '°';
}

// ============================================================
//  STATUS UPDATE
// ============================================================
function onStatus(data) {
  const pos = data.positions || [];
  const mov = data.moving    || [];
  for (let i = 0; i < NUM; i++) {
    state.positions[i] = pos[i] ?? 0;
    state.moving[i]    = mov[i] ?? false;

    const p = document.getElementById(`pos-${i+1}`);
    const d = document.getElementById(`dot-${i+1}`);
    const c = document.getElementById(`card-${i+1}`);

    if (p) p.textContent = (state.positions[i]).toFixed(2) + '°';
    if (d) d.className   = 'moving-dot' + (state.moving[i] ? ' on' : '');
    if (c) c.className   = 'motor-card' + (state.moving[i] ? ' active' : '');
  }
}

// ============================================================
//  COMMANDS
// ============================================================
function sendCmd(command, motorId=0, angle=0, speed=0, accel=0) {
  const payload = { command, motor_id: motorId, angle, speed, accel };
  socket.emit('cmd', payload);
  log(`→ ${command} M${motorId} ang=${angle} spd=${speed} acc=${accel}`, 'tx');
  // Also via REST as fallback
  fetch('/api/cmd', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload),
  }).catch(() => {});
}

function moveMotor(i) {
  const angle = parseFloat(document.getElementById(`anginp-${i}`).value) || 0;
  const speed = parseFloat(document.getElementById(`spdinp-${i}`).value) || gSpeed;
  const accel = parseFloat(document.getElementById(`accinp-${i}`).value) || gAccel;
  sendCmd('MOVE', i, angle, speed, accel);
}

function zeroMotor(i) {
  sendCmd('ZERO', i);
  log(`ZERO M${i}`, 'info');
}

function moveWait(i) {
  moveMotor(i);
  // Poll until motor stops
  const poll = setInterval(() => {
    fetch('/api/status').then(r => r.json()).then(d => {
      if (d.moving && !d.moving[i-1]) {
        clearInterval(poll);
        log(`✓ M${i} reached target`, 'rx');
      }
    }).catch(() => clearInterval(poll));
  }, 200);
}

// ============================================================
//  LOG
// ============================================================
const logBox = document.getElementById('log-box');
function log(msg, cls='info') {
  const now = new Date();
  const ts  = now.toTimeString().slice(0,8);
  const el  = document.createElement('div');
  el.className = `entry ${cls}`;
  el.innerHTML = `<span class="ts">${ts}</span>${msg}`;
  logBox.prepend(el);
  if (logBox.children.length > 200) logBox.removeChild(logBox.lastChild);
}

socket.on('status', d => {
  if (d.raw) log(d.raw, 'rx');
});
</script>

</body>
</html>
